@rendermode InteractiveAuto
@page "/order-history"
@using DTO
@using LajmiBlazorWebApp.Client.Services
@inject IOrderService OrderService
@inject UserSessionService UserSession

<h1>Mine tidligere ordrer</h1>

@if (!UserSession.IsLoggedIn)
{
    <p>Du skal være logget ind for at se din ordrehistorik.</p>
}
else if (orders == null)
{
    <p>Indlæser ordrer...</p>
}
else if (!orders.Any())
{
    <p>Du har ingen tidligere ordrer.</p>
}
else
{
    <div class="order-history-container">
        @foreach (var order in orders)
        {
            <div class="order-card">
                <div class="order-header">
                    <h3>Ordre — @order.OrderDate.ToString("dd. MMMM yyyy")</h3>
                    <span class="order-status status-@order.status.ToLower()">@order.status</span>
                </div>

                <table class="cart-table">
                    <thead>
                        <tr>
                            <th>Produkt</th>
                            <th>Antal</th>
                            <th>Stykpris</th>
                            <th>Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var line in order.Lines)
                        {
                            <tr>
                                <td>@line.ProductName</td>
                                <td>@line.Quantity</td>
                                <td>@line.UnitPrice.ToString("N2") kr.</td>
                                <td>@line.SubTotal.ToString("N2") kr.</td>
                            </tr>
                        }
                    </tbody>
                </table>

                <div class="order-total">
                    <strong>Total: @order.TotalAmount.ToString("N2") kr.</strong>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<OrderDto>? orders;

    protected override async Task OnInitializedAsync()
    {
        if (UserSession.IsLoggedIn && UserSession.CurrentUser != null)
        {
            orders = await OrderService.GetOrdersByCompanyIdAsync(UserSession.CurrentUser.CompanyId);
        }
    }
}
