@rendermode InteractiveAuto
@page "/products"
@using DTO
@inject ProductService ProductService
@using Models
@inject CartService CartService
@inject CalculateDiscountService calculateDiscountService
@inject UserService UserService
@inject UserSessionService UserSession
@inject FavoriteService FavoriteService
@implements IDisposable

<h1>Vores Produkter</h1>

@if (products == null || !products.Any())
{
    <p>Indlæser produkter...</p>
}
else
{
    <div class="product-grid">
        @foreach (var product in products)
        {
            <div class="product-card">
                <div class="image-container">
                    <img src="@product.ImageUrl" alt="@product.ProductName" />
                    
                    <button class="btn-favorite" @onclick="() => ToggleFavorite(product)">
                        @(isFavorite(product.ProductId) ? "⭐" : "☆")
                    </button>
                    
                </div>
                <div class="product-info">
                    <h3>@product.ProductName</h3>

                    <p class="price">
                        @if (discount > 0)
                        {
                            <span style="text-decoration: line-through;">
                                @product.ProductPrice.ToString("N2") kr
                            </span>
                            <br />
                            <strong>
                                @GetDiscountedPrice(product).ToString("N2") kr
                            </strong>
                        }
                        else
                        {
                            <span>
                                @product.ProductPrice.ToString("N2") kr
                            </span>
                        }
                    </p>

                    <button class="btn-buy" @onclick="() => PlaceInCart(product.ProductId)">
                        Tilføj til kurv
                    </button>
                    
                </div>
            </div>
        }
    </div>
}

@code {
    private decimal discount = 0.2m;
    private List<ProductDto> products = new();

    protected override async Task OnInitializedAsync()
    {
        FavoriteService.OnFavoriteChanged += StateHasChanged;
        products = await ProductService.GetProductsAsync();
    }

    public void Dispose()
    {
        FavoriteService.OnFavoriteChanged -= StateHasChanged;
    }

    private void PlaceInCart(Guid productId)
    {
        var productDto = products.FirstOrDefault(p => p.ProductId == productId);

        if (productDto != null)
        {
            CartService.AddProduct(productDto);
            Console.WriteLine($"Tilføjet: {productDto.ProductName}");
        }

        CartService.AddProductcounter();
    }

    private decimal GetDiscountedPrice(ProductDto productDto)
    {
        decimal discount = 0.2m; // dummy
        return calculateDiscountService.CalculatePrice(productDto, discount);
    }

    private bool isFavorite(Guid productId) => FavoriteService.FavoriteProducts.Any(p => p.ProductId == productId);

    private async Task ToggleFavorite(ProductDto product)
    {
        await FavoriteService.ToggleFavorite(product);
    }
}
