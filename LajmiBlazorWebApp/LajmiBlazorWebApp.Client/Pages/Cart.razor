@rendermode InteractiveAuto
@page "/cart"
@using LajmiBlazorWebApp.Client.Services
@using Models
@inject BasketService basketService

<h1>Din Indkøbskurv</h1>

@if (basketService.Items.Count == 0)
{
    <p>Din kurv er tom. Gå til produkter for at handle.</p>
}
else
{
    <div class="cart-container">
        <table class="cart-table">
            <thead>
            <tr>
                <th>Produkt</th>
                <th>Pris</th>
                <th>Antal</th>
                <th>Total</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var item in basketService.Items)
            {
                <tr>
                    <td>
                        <div class="cart-item-info">
                            <img src="@item.ImageUrl" alt="@item.ProductName" class="cart-image"/>
                            <span>@item.ProductName</span>
                        </div>
                    </td>
                    <!-- Overstreger pris uden rabat og viser prisen med rabat -->
                    <td>  @if (discount > 0)
                          {
                              <span style="text-decoration: line-through;">
                                  @item.ProductPrice.ToString("N2") kr.
                              </span>
                              <br />
                              <strong>
                                  @basketService.GetDiscountedPrice(item, discount).ToString("N2") kr.
                              </strong>
                          }
                          else
                          {
                              <span>
                                  @item.ProductPrice.ToString("N2") kr.
                              </span>
                          }</td>
                </tr>
            }
            </tbody>
        </table>

        <div class="cart-summary">
            <h3>Samlet beløb: @basketService.GetTotalPrice(discount).ToString("N2") kr.</h3>
            <button class="btn-checkout">Gå til betaling</button>
        </div>
    </div>
}
@code {
    // Dette er bare dummy data. Fjernes senere
    private decimal discount = 0.2m;
}