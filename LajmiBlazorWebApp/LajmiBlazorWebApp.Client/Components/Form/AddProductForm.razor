@using DTO

<div class="product-container">
    <div class="field-group">
        <label class="label">Navn</label>
        <input @bind="product.Name" class="input-field" placeholder="Indtast produktnavn" />
    </div>

    <div class="field-group">
        <label class="label">Beskrivelse</label>
        <textarea @bind="product.Description" class="input-field" rows="3" placeholder="Indtast beskrivelse"></textarea>
    </div>

    <div class="row">
        <div class="field-group half">
            <label class="label">Pris (kr.)</label>
            <input type="number" @bind="product.Price" class="input-field" placeholder="Indtast pris" />
        </div>
        <div class="field-group half">
            <label class="label">Vægt</label>
            <select @bind="product.ProductWeight" class="input-field">
                <option value="0.25">250g</option>
                <option value="0.5">500g</option>
                <option value="1.0">1000g</option>
            </select>
        </div>
    </div>

    <div class="field-group">
        <label class="label">Billede URL</label>
        <input @bind="product.ImageUrl" class="input-field" placeholder="Indtast billede URL" />
    </div>

    <button class="save-button" @onclick="Save">Gem produkt</button>
</div>

@code {
    private ProductDto product = new ProductDto { Vat = 25, ProductWeight = 0.5 };
    
    [Parameter] public EventCallback<ProductDto> OnSave { get; set; }

    private async Task Save()
    {
        await OnSave.InvokeAsync(product);
        
        
        product = new ProductDto { Vat = 25, ProductWeight = 0.5 };
    }
}
