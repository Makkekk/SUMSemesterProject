@rendermode InteractiveServer
@inject UserService userservice
@inject UserSessionService session
@inject NavigationManager nav
@page "/login"
@using LajmiBlazorWebApp.Client.Services
@using Models

<div class="login-wrapper">
    <div class="login-card">
        <h2>B2B Login</h2>

        <div class="form-group">
            <label>Brugernavn</label>
            <input type="text" @bind="username" placeholder="Dit brugernavn" />
        </div>

        <div class="form-group">
            <label>Kodeord</label>
            <input type="password" @bind="password" placeholder="Dit kodeord" />
        </div>

        <button class="login-btn" @onclick="Submit">Log ind</button>
        
        <p>
            <a href="@(nav.GetUriWithQueryParameters("Register", new Dictionary<string, object?> { ["ReturnUrl"] = ReturnUrl }))">Register as a new user</a>
        </p>

        @if (fejlbesked != null)
        {
            <p class="error-msg">@fejlbesked</p>
        }
    </div>
</div>

@code {
    string? fejlbesked;
    string username;
    string password;
    [SupplyParameterFromQuery] private string? ReturnUrl { get; set; }

    private async Task Submit()
    {
        fejlbesked = null;
        try
        {
            var user = await userservice.LoginAsync(username, password);

            if (user == null)
            {
                fejlbesked = "Forkert brugernavn eller kodeord";
                return;
            }

            session.Login(user);

            if (user.IsAdmin)
            {
                nav.NavigateTo("/AdminPage");
            }
            else
            {
                nav.NavigateTo("/");
            }
        }
        catch (Exception ex)
        {
            fejlbesked = $"Serverfejl: {ex.Message}";
        }
    }
}
