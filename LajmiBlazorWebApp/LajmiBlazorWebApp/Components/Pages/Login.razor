@rendermode InteractiveAuto
@inject UserService userservice
@inject UserSessionService session
@inject NavigationManager nav
@page "/login"
@using LajmiBlazorWebApp.Client.Services
<div class="container text-center">
    <div class="row">
        <div class="col-6">
            <h3>B2B Login</h3>
        </div>
    </div>
    <div class="row">
        <div class="col-6">
            <label>Brugernavn:</label>
        </div>
        <div class="col-6">
            <input type="text" @bind="username" />
        </div>
    </div>
    <div class="row">
        <div class="col-6">
            <label>Kodeord:</label>
        </div>
        <div class="col-6">
            <input type="password" @bind="password" />
        </div>
    </div>
    <div class="row">
        <div class="col-12">
            <input type="submit" value="Login" @onclick="Submit" />
        </div>
    </div>
</div>

@if (fejlbesked != null)
{
    <p style="color:red">@fejlbesked</p>
}
@code {
    string? fejlbesked;
    string username;
    string password;
    private async Task Submit()
    {
        fejlbesked = null;
       var user = await userservice.LoginAsync(username, password);

       if (user == null)
       {
           fejlbesked = "Forkert brugernavn";
           return;
       }
        session.Login(user);
        nav.NavigateTo("/");
        
    }
}