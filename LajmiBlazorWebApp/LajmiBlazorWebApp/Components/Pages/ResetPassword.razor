@page "/ResetPassword"
@using System.ComponentModel.DataAnnotations
@using System.Net.Http.Json
@using DTO
@inject HttpClient HttpClient
@inject NavigationManager Nav

<PageTitle>Reset password</PageTitle>

<h1>Reset password</h1>

@if (string.IsNullOrWhiteSpace(Token))
{
    <p class="text-danger">Ugyldigt eller manglende token.</p>
}
else
{
    <EditForm Model="Input" FormName="reset-password" OnValidSubmit="SubmitAsync">
        <DataAnnotationsValidator/>
        <ValidationSummary class="text-danger"/>

        <div class="mb-3">
            <label class="form-label">Nyt password</label>
            <InputText id="NewPassword" type="password" class="form-control" @bind-Value="Input.NewPassword"/>
            <ValidationMessage For="() => Input.NewPassword"/>
        </div>

        <div class="mb-3">
            <label class="form-label">Bekræft password</label>
            <InputText id="ConfirmPassword" type="password" class="form-control" @bind-Value="Input.ConfirmPassword"/>
            <ValidationMessage For="() => Input.ConfirmPassword"/>
        </div>

        <button class="btn btn-primary" type="submit">Gem nyt password</button>
    </EditForm>
}

@code {
    [SupplyParameterFromQuery] public string? Token { get; set; }

    [SupplyParameterFromForm]
    private ResetInputModel Input { get; set; } = new();

    private async Task SubmitAsync()
    {
        if (string.IsNullOrWhiteSpace(Token))
            return;

        var response = await HttpClient.PostAsJsonAsync("api/auth/reset-password", new ResetPasswordDto
        {
            Token = Token,
            NewPassword = Input.NewPassword
        });

        if (response.IsSuccessStatusCode)
        {
            Nav.NavigateTo("/login");
        }
    }

    private sealed class ResetInputModel
    {
        [Required]
        //[MinLength(8)]
        public string NewPassword { get; set; } = string.Empty;

        [Required]
        [Compare(nameof(NewPassword))]
        public string ConfirmPassword { get; set; } = string.Empty;
    }

}